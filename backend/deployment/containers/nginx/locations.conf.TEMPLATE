location ~ ^(/(api|default-admin|admin-backend|file|backend|diagnostics|user)(/.*|$)) {
    resolver 127.0.0.11 valid=3s;

    limit_req zone=one burst=1000 nodelay;

    set $target http://backend:8000;
    rewrite ^(.*)$ $1 break;
    proxy_pass $target;
    proxy_set_header    X-Forwarded-Host $host;
    proxy_set_header    X-Forwarded-Server $host;
    proxy_set_header    X-Forwarded-Proto $scheme;
    proxy_set_header    X-Forwarded-For $proxy_add_x_forwarded_for;

    #auth_request /authcheck/documentation;
    #auth_request_set $username $upstream_http_x_forwarded_user;
    #proxy_set_header X-Forwarded-User $username;
    #proxy_hide_header X-Frame-Options;
    #error_page 403 = @error403login;
}

location ~ ^/documentation/(.*) {
    resolver 127.0.0.11 valid=3s;

    set $target http://documentation:8300;
    rewrite ^/documentation/(.*)$ /$1 break;
    proxy_pass $target;
    proxy_set_header    X-Forwarded-Host $host;
    proxy_set_header    X-Forwarded-Server $host;
    proxy_set_header    X-Forwarded-Proto $scheme;
    proxy_set_header    X-Forwarded-For $proxy_add_x_forwarded_for;

    #auth_request /authcheck/documentation;
    #auth_request_set $username $upstream_http_x_forwarded_user;
    #proxy_set_header X-Forwarded-User $username;
    #proxy_hide_header X-Frame-Options;
    #error_page 403 = @error403login;
}

